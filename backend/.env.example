# Backend Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to Git

PROJECT_NAME="EDUMITHRA -- AI Learning Copilot"
DATABASE_URL="sqlite:///./edumithra.db"

# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="your-strong-random-secret-here"

# Get from https://console.groq.com
GROQ_API_KEY="your-groq-api-key"

# Get from https://console.cloud.google.com (YouTube Data API v3)
YOUTUBE_API_KEY="your-youtube-api-key"

# Your Vercel frontend URL (set after deploying frontend)
# Example: https://edumithra.vercel.app
FRONTEND_URL="*"
