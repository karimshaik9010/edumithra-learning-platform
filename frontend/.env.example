# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git

# Backend API URL (no trailing /api — it is added automatically by lib/api.ts)
# Local development:
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"

# Production (set this in Vercel dashboard, not here):
# NEXT_PUBLIC_API_URL="https://edumithra-backend.onrender.com"
